<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SnowrunnerMerger.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SnowrunnerMerger.Desktop.Views.LoginPageView"
             x:DataType="vm:LoginPageViewModel">
    <Border>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
            <TextBlock Text="Login" FontSize="24" FontWeight="Bold" Margin="0 10" HorizontalAlignment="Center"/>
            <TextBlock Text="Click the button bellow to sign-in through your browser" Margin="0 10" />
            <Button Content="Sign In" Margin="0 10" HorizontalAlignment="Center" Classes="accent" Command="{Binding LoginCommand}" />
        </StackPanel>
    </Border>
</UserControl>
